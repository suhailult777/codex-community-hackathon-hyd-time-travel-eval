NVIDIA_API_KEY=your_nvidia_api_key_here
TTE_MODEL_GENERATOR=moonshotai/kimi-k2.5
TTE_MODEL_AGENT=meta/llama-3.1-8b-instruct
TTE_API_BASE_URL=https://integrate.api.nvidia.com/v1
# Set this at or below your provider quota. If your plan is capped at 40 rpm,
# keeping this at 40 or slightly lower is the safest setting.
TTE_MAX_REQUESTS_PER_MINUTE=40
TTE_LLM_MAX_RETRIES=2
TTE_LLM_BACKOFF_BASE_SECONDS=1.5
TTE_LLM_BACKOFF_MAX_SECONDS=20.0
TTE_LLM_REQUEST_TIMEOUT_SECONDS=20.0
TTE_ENABLE_LLM_JUDGE=false
TTE_MAX_BRANCHES=4
TTE_MAX_STEPS_PER_BRANCH=8
TTE_LOG_DIR=./logs
