TTE_PROVIDER=openai
NVIDIA_API_KEY=your_nvidia_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
TTE_NVIDIA_MODEL_GENERATOR=moonshotai/kimi-k2.5
TTE_NVIDIA_MODEL_AGENT=moonshotai/kimi-k2.5
TTE_NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
TTE_OPENAI_MODEL_GENERATOR=gpt-5.4-nano
TTE_OPENAI_MODEL_AGENT=gpt-5.4-nano
TTE_OPENAI_API_BASE_URL=https://api.openai.com/v1
TTE_EXECUTION_MODE=auto
TTE_PROVIDER_PROFILE=auto
# Set this at or below your provider quota. If your plan is capped at 40 rpm,
# keeping this at 40 or slightly lower is the safest setting.
TTE_MAX_REQUESTS_PER_MINUTE=40
TTE_RATE_LIMIT_SAFETY_FACTOR=0.8
TTE_LLM_MAX_RETRIES=2
TTE_LLM_BACKOFF_BASE_SECONDS=1.5
TTE_LLM_BACKOFF_MAX_SECONDS=20.0
TTE_LLM_REQUEST_TIMEOUT_SECONDS=20.0
TTE_ENABLE_LLM_JUDGE=true
TTE_AGENT_BATCH_HISTORY=2
TTE_MAX_BRANCHES=4
TTE_MAX_STEPS_PER_BRANCH=8
TTE_LOG_DIR=./logs
TTE_CACHE_PATH=./logs/llm_cache.sqlite3
