# Provider key (set at least one; NVIDIA takes precedence in current config)
NVIDIA_API_KEY=nvapi-REPLACE_ME
# KIMI_API_KEY=REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# Provider endpoint and models
TTE_API_BASE_URL=https://integrate.api.nvidia.com/v1
TTE_MODEL_GENERATOR=moonshotai/kimi-k2.5
TTE_MODEL_AGENT=moonshotai/kimi-k2.5

# Throughput and retry tuning
TTE_MAX_REQUESTS_PER_MINUTE=40
TTE_LLM_MAX_RETRIES=2
TTE_LLM_BACKOFF_BASE_SECONDS=1.5
TTE_LLM_BACKOFF_MAX_SECONDS=20.0
TTE_LLM_REQUEST_TIMEOUT_SECONDS=20.0

# Evaluation options
TTE_ENABLE_LLM_JUDGE=false
TTE_MAX_BRANCHES=4
TTE_MAX_STEPS_PER_BRANCH=8

# Logging
TTE_LOG_DIR=./logs
